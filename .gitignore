moc_*.cpp
ui_*.h
qrc_*.cpp

# Qt build directories
.qt/

# Executables (root level)
*.exe
*.out

# Object files
*.o
*.obj
*.lo

# Compiled libraries
*.so
*.so.*
*.dylib
*.dll

# IDE files
.vscode/
.idea/
*.pro.user
*.pro.user.*

# Debug files
*.dSYM/
*.su

# Resources (compiled translations)
resources/qm/*

# Temporary files
*.tmp
*.log
*~
